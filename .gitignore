Thumbs.db
*~

# Runtime and user data
config.json
.portable
logs/
*.log

# CAN captures and databases are ignored by default to prevent accidental leaks.
# Curated public examples under examples/ are explicitly allowed.
*.csv
*.dbc
!examples/*.csv
!examples/*.dbc
